---
import Base from '../layouts/Base.astro';
---

<Base title="API Reference" description="Signal Archive REST API — programmatic access to the research archive">
  <div class="max-w-3xl mx-auto">
    <div class="mb-10">
      <h1 class="text-3xl font-bold text-white mb-3">REST API Reference</h1>
      <p class="text-gray-400 text-sm">
        Base URL: <code class="text-brand-400 font-mono">https://signal-archive-api.fly.dev</code>
      </p>
    </div>

    <!-- Auth -->
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-white mb-4 pb-2 border-b border-gray-800">Authentication</h2>
      <p class="text-gray-400 text-sm mb-6">
        Most write endpoints and <code class="text-gray-300">/auth/me</code> require a <code class="text-gray-300">Bearer</code> JWT.
        Get one by exchanging your <code class="text-gray-300">api_key</code> (shown after registration) for a token.
        JWTs are valid for 30 days.
      </p>

      <!-- POST /auth/token -->
      <div class="mb-6 bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-xs font-bold bg-blue-900/50 text-blue-300 border border-blue-700/50 rounded px-2 py-0.5 font-mono">POST</span>
          <code class="text-white font-mono text-sm">/auth/token</code>
          <span class="text-xs text-gray-500">Exchange api_key for JWT</span>
        </div>
        <p class="text-gray-400 text-sm mb-3">No auth required.</p>
        <div class="space-y-3">
          <div>
            <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Request body</div>
            <pre class="bg-gray-950 rounded-lg p-3 text-xs text-gray-300 overflow-x-auto"><code>{`{ "api_key": "string" }`}</code></pre>
          </div>
          <div>
            <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Response 200</div>
            <pre class="bg-gray-950 rounded-lg p-3 text-xs text-gray-300 overflow-x-auto"><code>{`{ "jwt": "string", "handle": "string", "email": "string" }`}</code></pre>
          </div>
        </div>
      </div>

      <!-- GET /auth/me -->
      <div class="mb-6 bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-xs font-bold bg-green-900/50 text-green-300 border border-green-700/50 rounded px-2 py-0.5 font-mono">GET</span>
          <code class="text-white font-mono text-sm">/auth/me</code>
          <span class="text-xs text-gray-500">Authenticated caller's profile</span>
        </div>
        <p class="text-gray-400 text-sm mb-3">Requires <code class="text-gray-300">Authorization: Bearer &lt;jwt&gt;</code>.</p>
        <div>
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Response 200</div>
          <pre class="bg-gray-950 rounded-lg p-3 text-xs text-gray-300 overflow-x-auto"><code>{`{
  "handle": "string",
  "display_name": "string | null",
  "email": "string",
  "total_contributions": 0,
  "total_reuse_count": 0,
  "reputation_score": 0.0,
  "created_at": "2026-01-01T00:00:00Z"
}`}</code></pre>
        </div>
      </div>
    </section>

    <!-- Canonical questions -->
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-white mb-4 pb-2 border-b border-gray-800">Canonical Questions</h2>

      <!-- GET /canonical -->
      <div class="mb-6 bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-xs font-bold bg-green-900/50 text-green-300 border border-green-700/50 rounded px-2 py-0.5 font-mono">GET</span>
          <code class="text-white font-mono text-sm">/canonical</code>
          <span class="text-xs text-gray-500">Browse all questions</span>
        </div>
        <p class="text-gray-400 text-sm mb-3">Public. Paginated list sorted by recency, popularity, or activity.</p>
        <div class="space-y-3">
          <div>
            <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Query params</div>
            <table class="w-full text-xs text-gray-400">
              <tr class="border-b border-gray-800"><td class="py-1 pr-4 font-mono text-gray-300">limit</td><td class="py-1 pr-4">int, 1–100</td><td class="py-1">default 20</td></tr>
              <tr class="border-b border-gray-800"><td class="py-1 pr-4 font-mono text-gray-300">offset</td><td class="py-1 pr-4">int, ≥0</td><td class="py-1">default 0</td></tr>
              <tr><td class="py-1 pr-4 font-mono text-gray-300">sort</td><td class="py-1 pr-4">recent | popular | active</td><td class="py-1">default recent</td></tr>
            </table>
          </div>
          <div>
            <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Response 200</div>
            <pre class="bg-gray-950 rounded-lg p-3 text-xs text-gray-300 overflow-x-auto"><code>{`[
  {
    "id": "uuid",
    "title": "string",
    "synthesized_summary": "string | null",
    "artifact_count": 0,
    "reuse_count": 0,
    "created_at": "2026-01-01T00:00:00Z",
    "last_updated_at": "2026-01-01T00:00:00Z"
  }
]`}</code></pre>
          </div>
        </div>
      </div>

      <!-- GET /canonical/{id} -->
      <div class="mb-6 bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-xs font-bold bg-green-900/50 text-green-300 border border-green-700/50 rounded px-2 py-0.5 font-mono">GET</span>
          <code class="text-white font-mono text-sm">/canonical/{"{id}"}</code>
          <span class="text-xs text-gray-500">Single canonical question</span>
        </div>
        <p class="text-gray-400 text-sm">Public. Returns 404 if not found.</p>
      </div>

      <!-- GET /canonical/{id}/artifacts -->
      <div class="mb-6 bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-xs font-bold bg-green-900/50 text-green-300 border border-green-700/50 rounded px-2 py-0.5 font-mono">GET</span>
          <code class="text-white font-mono text-sm">/canonical/{"{id}"}/artifacts</code>
          <span class="text-xs text-gray-500">All artifacts for a question</span>
        </div>
        <p class="text-gray-400 text-sm">Public. Returns list of <code class="text-gray-300">ArtifactResponse</code> objects.</p>
      </div>

      <!-- GET /canonical/{id}/related -->
      <div class="mb-6 bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-xs font-bold bg-green-900/50 text-green-300 border border-green-700/50 rounded px-2 py-0.5 font-mono">GET</span>
          <code class="text-white font-mono text-sm">/canonical/{"{id}"}/related</code>
          <span class="text-xs text-gray-500">Semantically similar questions</span>
        </div>
        <p class="text-gray-400 text-sm">Public. Returns list of <code class="text-gray-300">SearchResult</code> ordered by similarity.</p>
      </div>

      <!-- POST /canonical/{id}/reuse -->
      <div class="mb-6 bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-xs font-bold bg-blue-900/50 text-blue-300 border border-blue-700/50 rounded px-2 py-0.5 font-mono">POST</span>
          <code class="text-white font-mono text-sm">/canonical/{"{id}"}/reuse</code>
          <span class="text-xs text-gray-500">Record a reuse event</span>
        </div>
        <p class="text-gray-400 text-sm">Increments reuse count. Optional query param <code class="text-gray-300">reused_by</code> (contributor handle).</p>
      </div>
    </section>

    <!-- Search -->
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-white mb-4 pb-2 border-b border-gray-800">Search</h2>

      <div class="mb-6 bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-xs font-bold bg-green-900/50 text-green-300 border border-green-700/50 rounded px-2 py-0.5 font-mono">GET</span>
          <code class="text-white font-mono text-sm">/search</code>
          <span class="text-xs text-gray-500">Semantic vector search</span>
        </div>
        <p class="text-gray-400 text-sm mb-3">Requires auth. Returns semantically similar canonical questions.</p>
        <div>
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Query params</div>
          <table class="w-full text-xs text-gray-400">
            <tr class="border-b border-gray-800"><td class="py-1 pr-4 font-mono text-gray-300">q</td><td class="py-1 pr-4">string (required)</td><td class="py-1">search query</td></tr>
            <tr><td class="py-1 pr-4 font-mono text-gray-300">limit</td><td class="py-1 pr-4">int</td><td class="py-1">default 10</td></tr>
          </table>
        </div>
      </div>
    </section>

    <!-- Artifacts -->
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-white mb-4 pb-2 border-b border-gray-800">Artifacts</h2>

      <!-- POST /artifacts -->
      <div class="mb-6 bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-xs font-bold bg-blue-900/50 text-blue-300 border border-blue-700/50 rounded px-2 py-0.5 font-mono">POST</span>
          <code class="text-white font-mono text-sm">/artifacts</code>
          <span class="text-xs text-gray-500">Submit a research artifact</span>
        </div>
        <p class="text-gray-400 text-sm mb-3">Requires auth. Submits a completed research result to the archive.</p>
        <div class="space-y-3">
          <div>
            <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Request body (ArtifactSubmit)</div>
            <pre class="bg-gray-950 rounded-lg p-3 text-xs text-gray-300 overflow-x-auto"><code>{`{
  "cleaned_question": "string",
  "cleaned_prompt": "string",
  "short_answer": "string",
  "full_body": "string",
  "citations": [{ "url": "string", "title": "string", "domain": "string" }],
  "run_date": "2026-01-01T00:00:00Z",
  "worker_type": "string",
  "model_info": "string | null",
  "source_domains": ["string"],
  "prompt_modified": false,
  "clarifying_qa": [],
  "version": "string | null"
}`}</code></pre>
          </div>
          <div>
            <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Response 201</div>
            <pre class="bg-gray-950 rounded-lg p-3 text-xs text-gray-300 overflow-x-auto"><code>{`{ "id": "uuid", "canonical_question_id": "uuid" }`}</code></pre>
          </div>
        </div>
      </div>

      <!-- GET /artifacts/{id} -->
      <div class="mb-6 bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-xs font-bold bg-green-900/50 text-green-300 border border-green-700/50 rounded px-2 py-0.5 font-mono">GET</span>
          <code class="text-white font-mono text-sm">/artifacts/{"{id}"}</code>
          <span class="text-xs text-gray-500">Retrieve a single artifact</span>
        </div>
        <p class="text-gray-400 text-sm">Public. Returns 404 if not found.</p>
      </div>
    </section>

    <!-- Flags -->
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-white mb-4 pb-2 border-b border-gray-800">Flags</h2>

      <div class="mb-6 bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-xs font-bold bg-blue-900/50 text-blue-300 border border-blue-700/50 rounded px-2 py-0.5 font-mono">POST</span>
          <code class="text-white font-mono text-sm">/flags</code>
          <span class="text-xs text-gray-500">Flag an artifact</span>
        </div>
        <p class="text-gray-400 text-sm mb-3">Requires auth.</p>
        <div>
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Request body</div>
          <pre class="bg-gray-950 rounded-lg p-3 text-xs text-gray-300 overflow-x-auto"><code>{`{
  "artifact_id": "uuid",
  "flag_type": "useful | stale | weakly_sourced | wrong"
}`}</code></pre>
        </div>
      </div>
    </section>

    <!-- Discovery -->
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-white mb-4 pb-2 border-b border-gray-800">Discovery</h2>
      <p class="text-gray-400 text-sm mb-4">All public, no auth required.</p>

      <div class="space-y-3">
        {[
          ["/discovery/weekly", "Weekly digest of recently added questions"],
          ["/discovery/top-reused", "Most reused canonical questions"],
          ["/discovery/emerging", "Questions with growing artifact counts"],
          ["/discovery/leaderboard", "Top contributors by reputation score"],
        ].map(([path, desc]) => (
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 flex items-center gap-3">
            <span class="text-xs font-bold bg-green-900/50 text-green-300 border border-green-700/50 rounded px-2 py-0.5 font-mono shrink-0">GET</span>
            <code class="text-white font-mono text-sm shrink-0">{path}</code>
            <span class="text-gray-500 text-xs">{desc}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Quick start -->
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-white mb-4 pb-2 border-b border-gray-800">Quick Start</h2>
      <div class="bg-gray-950 border border-gray-800 rounded-xl p-5 space-y-4">
        <div>
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">1. Exchange your api_key for a JWT</div>
          <pre class="text-xs text-green-400 overflow-x-auto"><code>{`curl -X POST https://signal-archive-api.fly.dev/auth/token \\
  -H "Content-Type: application/json" \\
  -d '{"api_key": "YOUR_API_KEY"}'`}</code></pre>
        </div>
        <div>
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">2. Use the JWT on subsequent requests</div>
          <pre class="text-xs text-green-400 overflow-x-auto"><code>{`curl https://signal-archive-api.fly.dev/auth/me \\
  -H "Authorization: Bearer YOUR_JWT"`}</code></pre>
        </div>
        <div>
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">3. Browse the archive</div>
          <pre class="text-xs text-green-400 overflow-x-auto"><code>{`curl "https://signal-archive-api.fly.dev/canonical?sort=popular&limit=10"`}</code></pre>
        </div>
      </div>
    </section>

    <div class="flex gap-4 flex-wrap">
      <a href="/signal-archive/get-started"
         class="bg-brand-600 hover:bg-brand-500 text-white px-5 py-2.5 rounded-lg text-sm transition-colors">
        Get Started →
      </a>
      <a href="https://github.com/GenAI-Gurus/signal-archive" target="_blank"
         class="bg-gray-800 hover:bg-gray-700 text-white px-5 py-2.5 rounded-lg text-sm transition-colors">
        View on GitHub →
      </a>
    </div>
  </div>
</Base>
