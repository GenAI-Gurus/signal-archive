---
import Base from '../../layouts/Base.astro';
---

<Base title="Research Question">
  <div id="loading" class="animate-pulse space-y-4 max-w-4xl mx-auto">
    <div class="h-8 bg-gray-800 rounded w-3/4"></div>
    <div class="h-4 bg-gray-800 rounded w-full"></div>
    <div class="h-4 bg-gray-800 rounded w-4/5"></div>
  </div>
  <div id="content" class="hidden max-w-4xl mx-auto"></div>
  <div id="error" class="hidden text-center py-20 text-gray-500">
    Research question not found.
    <a id="back-link" href="#" class="block mt-4 text-brand-400 hover:underline">Back to search</a>
  </div>
</Base>

<script>
  import { getCanonical, getCanonicalArtifacts, getRelated, submitFlag, el, link, BASE } from '../../lib/api.js';
  import { isLoggedIn } from '../../lib/auth.js';
  import { marked } from 'marked';

  const loggedIn = isLoggedIn();

  const id = new URLSearchParams(window.location.search).get('id');
  document.getElementById('back-link').href = `${BASE}/search`;

  function buildProvenance(artifact) {
    const div = el('div', 'bg-gray-900 border border-gray-800 rounded-xl p-4 text-xs');
    div.appendChild(el('div', 'text-gray-500 uppercase tracking-wider mb-2 font-semibold', 'Provenance'));
    const grid = el('div', 'grid grid-cols-2 gap-1 text-gray-400');
    const date = new Date(artifact.run_date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    [
      ['🤖 Worker', artifact.worker_type],
      ['📅 Run', date],
      ['🔗 Sources', String((artifact.source_domains || []).length)],
      ['🧹 Cleaned', artifact.prompt_modified ? 'Yes' : 'No'],
    ].forEach(([label, value]) => {
      const row = el('div');
      row.appendChild(el('span', 'text-gray-500', label + ': '));
      row.appendChild(el('span', artifact.prompt_modified && label.includes('Cleaned') ? 'text-yellow-400' : 'text-gray-300', value));
      grid.appendChild(row);
    });
    div.appendChild(grid);
    return div;
  }

  function flagKey(artifactId, flagType) {
    return `flag:${artifactId}:${flagType}`;
  }

  function buildFlagButtons(artifactId) {
    const flags = [
      { type: 'useful', label: '👍 Useful', cls: 'text-green-400 border-green-800' },
      { type: 'stale', label: '⏰ Stale', cls: 'text-yellow-400 border-yellow-800' },
      { type: 'weakly_sourced', label: '⚠️ Weak sources', cls: 'text-orange-400 border-orange-800' },
      { type: 'wrong', label: '❌ Wrong', cls: 'text-red-400 border-red-800' },
    ];
    const container = el('div', 'flex gap-2 flex-wrap mt-4 pt-4 border-t border-gray-800');
    flags.forEach(f => {
      const alreadyFlagged = localStorage.getItem(flagKey(artifactId, f.type));
      const label = alreadyFlagged ? '✓ ' + f.label : f.label;
      const btn = el('button', `text-xs border px-3 py-1 rounded-full hover:opacity-80 cursor-pointer ${f.cls}`, label);
      if (alreadyFlagged) btn.disabled = true;
      btn.addEventListener('click', async () => {
        const ok = await submitFlag(artifactId, f.type);
        if (ok) {
          localStorage.setItem(flagKey(artifactId, f.type), '1');
          btn.textContent = '✓ ' + f.label;
          btn.disabled = true;
        }
      });
      container.appendChild(btn);
    });
    return container;
  }

  function buildQualityBadge(score) {
    if (score == null) return null;
    const [label, cls] =
      score >= 70 ? ['High quality', 'bg-green-900 text-green-300 border-green-700'] :
      score >= 40 ? ['Medium quality', 'bg-yellow-900 text-yellow-300 border-yellow-700'] :
                   ['Low quality', 'bg-red-900 text-red-300 border-red-700'];
    return el('span', `text-xs border px-2 py-0.5 rounded-full font-mono ${cls}`, `${label} · ${score}`);
  }

  async function load() {
    if (!id) {
      document.getElementById('loading').classList.add('hidden');
      document.getElementById('error').classList.remove('hidden');
      return;
    }

    const [cq, artifacts, related] = await Promise.all([
      getCanonical(id),
      getCanonicalArtifacts(id),
      getRelated(id),
    ]);

    document.getElementById('loading').classList.add('hidden');

    if (!cq) {
      document.getElementById('error').classList.remove('hidden');
      return;
    }

    document.title = cq.title + ' | Signal Archive';
    const content = document.getElementById('content');
    content.classList.remove('hidden');

    content.appendChild(el('div', 'text-xs text-brand-400 font-mono mb-2 uppercase tracking-wider', 'Research Question'));
    content.appendChild(el('h1', 'text-3xl font-bold text-white leading-snug mb-3', cq.title));
    const metaRow = el('div', 'flex gap-4 text-sm text-gray-500 mb-8');
    metaRow.appendChild(el('span', null, `📄 ${cq.artifact_count} artifact${cq.artifact_count !== 1 ? 's' : ''}`));
    metaRow.appendChild(el('span', null, `♻️ ${cq.reuse_count} reuse${cq.reuse_count !== 1 ? 's' : ''}`));
    content.appendChild(metaRow);

    const summaryBox = el('div', 'bg-gray-900 border border-gray-800 rounded-xl p-6 mb-8');
    summaryBox.appendChild(el('h2', 'text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3', 'Synthesized Answer'));
    if (loggedIn) {
      summaryBox.appendChild(el('p', 'text-gray-200 leading-relaxed', cq.synthesized_summary || 'Summary pending.'));
    } else {
      const nudge = el('div', 'text-center py-4');
      nudge.innerHTML = `<p class="text-gray-500 text-sm mb-3">Sign in to read the synthesized answer.</p><a href="${BASE}/login" class="bg-brand-600 hover:bg-brand-500 text-white font-semibold px-5 py-2 rounded-lg text-sm transition-colors">Sign in</a>`;
      summaryBox.appendChild(nudge);
    }
    content.appendChild(summaryBox);

    content.appendChild(el('h2', 'text-xl font-semibold text-white mb-4', 'Research Artifacts'));
    if (!artifacts.length) {
      content.appendChild(el('p', 'text-gray-500 italic mb-8', 'No artifacts yet.'));
    } else {
      // Build version-chain helpers
      const byId = new Map(artifacts.map(a => [a.id, a]));
      const STALENESS_DAYS = 180;
      const staleThreshold = new Date(Date.now() - STALENESS_DAYS * 86400 * 1000);
      const supersededIds = new Set(artifacts.map(a => a.supersedes_id).filter(Boolean));
      const activeArtifacts = artifacts.filter(a => !supersededIds.has(a.id));

      // Staleness banner — show if all active artifacts are older than threshold
      if (activeArtifacts.length > 0 && activeArtifacts.every(a => new Date(a.run_date) < staleThreshold)) {
        const newestDate = new Date(Math.max(...activeArtifacts.map(a => new Date(a.run_date)))).toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
        const banner = el('div', 'mb-6 bg-yellow-900/20 border border-yellow-700/30 rounded-xl px-5 py-4 flex items-start gap-3');
        banner.appendChild(el('span', 'text-yellow-400 text-lg shrink-0', '⚠️'));
        const bannerText = el('div');
        bannerText.appendChild(el('p', 'text-yellow-200 text-sm font-medium', 'This research may be outdated'));
        bannerText.appendChild(el('p', 'text-yellow-200/60 text-xs mt-1', `Last updated ${newestDate}. Run fresh research to supersede it and update the archive.`));
        banner.appendChild(bannerText);
        content.insertBefore(banner, content.querySelector('h2'));
      }

      activeArtifacts.forEach(a => {
        const card = el('div', 'bg-gray-900 border border-gray-800 rounded-xl p-6 mb-4');

        // Version banner if this artifact replaced an older one
        if (a.supersedes_id && byId.has(a.supersedes_id)) {
          const older = byId.get(a.supersedes_id);
          const olderDate = new Date(older.run_date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
          const banner = el('div', 'text-xs text-brand-400 mb-3 flex items-center gap-1');
          banner.textContent = `↩ Replaces version from ${olderDate}`;
          card.appendChild(banner);
        }

        const dateStr = new Date(a.run_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
        const header = el('div', 'flex items-center gap-3 mb-3 flex-wrap');
        header.appendChild(el('span', 'text-xs text-gray-500 font-mono', `${dateStr} · ${a.worker_type}`));
        if (a.contributor_handle) {
          header.appendChild(link(`${BASE}/contributor/?handle=${a.contributor_handle}`, 'text-xs text-brand-500 hover:text-brand-300 font-mono', `@${a.contributor_handle}`));
        }
        const badge = buildQualityBadge(a.quality_score);
        if (badge) header.appendChild(badge);
        card.appendChild(header);
        card.appendChild(el('p', 'text-gray-200 text-sm leading-relaxed mb-4', a.short_answer));
        if (loggedIn) {
          const details = document.createElement('details');
          details.className = 'text-sm text-gray-400 mb-2';
          const summary = el('summary', 'cursor-pointer hover:text-white mb-2', 'Full research body');
          const bodyDiv = el('div', 'prose prose-invert prose-sm max-w-none bg-gray-950 rounded p-4 overflow-auto max-h-96 mt-2');
          bodyDiv.innerHTML = marked.parse(a.full_body || '');
          details.appendChild(summary);
          details.appendChild(bodyDiv);
          card.appendChild(details);
        } else {
          const gate = el('p', 'text-xs text-gray-600 mb-2 italic');
          gate.innerHTML = `<a href="${BASE}/login" class="text-brand-400 hover:underline">Sign in</a> to read the full research body.`;
          card.appendChild(gate);
        }
        card.appendChild(buildProvenance(a));
        card.appendChild(buildFlagButtons(a.id));

        // Collapsible older version(s) chained from this artifact
        if (a.supersedes_id && byId.has(a.supersedes_id)) {
          const older = byId.get(a.supersedes_id);
          const olderDate = new Date(older.run_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
          const oldDetails = document.createElement('details');
          oldDetails.className = 'mt-4 pt-4 border-t border-gray-800';
          const oldSummary = el('summary', 'cursor-pointer text-xs text-gray-600 hover:text-gray-400', `Older version · ${olderDate} · ${older.worker_type}`);
          oldDetails.appendChild(oldSummary);
          const oldBody = el('div', 'mt-3 space-y-2');
          oldBody.appendChild(el('p', 'text-gray-400 text-xs leading-relaxed', older.short_answer));
          const oldBadge = buildQualityBadge(older.quality_score);
          if (oldBadge) oldBody.appendChild(oldBadge);
          oldDetails.appendChild(oldBody);
          card.appendChild(oldDetails);
        }

        content.appendChild(card);
      });
    }

    content.appendChild(el('h2', 'text-xl font-semibold text-white mb-4 mt-8', 'Related Questions'));
    if (!related.length) {
      content.appendChild(el('p', 'text-gray-500 italic text-sm', 'No related questions yet.'));
    } else {
      related.forEach(r => {
        const a = link(
          `${BASE}/canonical/?id=${r.canonical_question_id}`,
          'block bg-gray-900 border border-gray-800 hover:border-brand-500/40 rounded-lg px-4 py-3 text-sm text-gray-300 hover:text-white transition-colors mb-2',
          r.title
        );
        const badge = el('span', 'text-xs text-gray-600 ml-2', `${Math.round(r.similarity * 100)}% similar`);
        a.appendChild(badge);
        content.appendChild(a);
      });
    }
  }

  load();
</script>
