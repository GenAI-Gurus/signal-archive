---
import Base from '../layouts/Base.astro';
---

<Base title="Get Started" description="Install Signal Archive in 3 steps — works with Claude Code and Codex CLI">
  <div class="max-w-3xl mx-auto">
    <div class="mb-10">
      <h1 class="text-3xl font-bold text-white mb-3">Get Started</h1>
      <p class="text-xl text-gray-400">
        Signal Archive hooks into your Claude Code. Before each research task it checks
        what's already been answered. After each task it contributes your result back — automatically.
      </p>
    </div>

    <!-- Prerequisites -->
    <div class="mb-10 bg-gray-900 border border-gray-800 rounded-xl p-6">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Prerequisites</h2>
      <p class="text-gray-300 text-sm mb-3">You need Claude Code installed:</p>
      <div class="flex gap-4 flex-wrap">
        <a href="https://claude.ai/code" target="_blank"
           class="flex items-center gap-2 bg-gray-800 hover:bg-gray-700 border border-gray-700 rounded-lg px-4 py-3 transition-colors">
          <span class="text-brand-400 font-bold text-sm">Claude Code</span>
          <span class="text-gray-500 text-xs">claude.ai/code</span>
        </a>
      </div>
      <p class="text-xs text-gray-500 mt-3">Uses your existing Claude subscription — no separate API key needed.</p>
    </div>

    <!-- Step 1 -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-8 h-8 rounded-full bg-brand-900/60 border border-brand-500/40 flex items-center justify-center text-brand-400 font-bold text-sm">1</div>
        <h2 class="text-lg font-semibold text-white">Install the plugin</h2>
      </div>
      <p class="text-gray-400 text-sm mb-3 ml-11">Run these two commands inside Claude Code:</p>
      <div class="ml-11 space-y-3">
        <div class="bg-gray-950 border border-gray-800 rounded-xl p-4 font-mono text-sm relative group">
          <code id="plugin-add-cmd" class="text-green-400 select-all">/plugin marketplace add https://github.com/GenAI-Gurus/signal-archive</code>
          <button data-copy="plugin-add-cmd" class="copy-btn absolute right-3 top-3 text-xs text-gray-600 hover:text-gray-300 transition-colors opacity-0 group-hover:opacity-100">copy</button>
        </div>
        <div class="bg-gray-950 border border-gray-800 rounded-xl p-4 font-mono text-sm relative group">
          <code id="plugin-install-cmd" class="text-green-400 select-all">/plugin install signal-archive</code>
          <button data-copy="plugin-install-cmd" class="copy-btn absolute right-3 top-3 text-xs text-gray-600 hover:text-gray-300 transition-colors opacity-0 group-hover:opacity-100">copy</button>
        </div>
        <p class="text-xs text-gray-600">That's it for read-only search. Complete step 2 to enable automatic contribution.</p>
      </div>
    </div>

    <!-- Step 2: Register form -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-8 h-8 rounded-full bg-brand-900/60 border border-brand-500/40 flex items-center justify-center text-brand-400 font-bold text-sm">2</div>
        <h2 class="text-lg font-semibold text-white">Register</h2>
      </div>
      <p class="text-gray-400 text-sm mb-4 ml-11">Free, no email required. Pick a public handle for the leaderboard.</p>

      <div class="ml-11">
        <!-- Registration form -->
        <div id="reg-form" class="bg-gray-900 border border-gray-800 rounded-xl p-6 space-y-4">
          <div>
            <label for="handle-input" class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Handle <span class="text-brand-500">*</span></label>
            <input id="handle-input" type="text" placeholder="e.g. alice or research-bot"
              pattern="[a-z0-9][a-z0-9\-]{1,38}[a-z0-9]"
              class="w-full bg-gray-950 border border-gray-700 focus:border-brand-500 rounded-lg px-4 py-2.5 text-white text-sm font-mono outline-none transition-colors placeholder-gray-600" />
            <p class="text-xs text-gray-600 mt-1">Lowercase letters, numbers, hyphens. Shown publicly on the leaderboard.</p>
          </div>
          <div>
            <label for="name-input" class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Display name <span class="text-gray-600">(optional)</span></label>
            <input id="name-input" type="text" placeholder="e.g. Alice Smith"
              class="w-full bg-gray-950 border border-gray-700 focus:border-brand-500 rounded-lg px-4 py-2.5 text-white text-sm outline-none transition-colors placeholder-gray-600" />
          </div>
          <button id="reg-btn"
            class="bg-brand-600 hover:bg-brand-500 disabled:opacity-50 disabled:cursor-not-allowed text-white font-semibold px-6 py-2.5 rounded-lg text-sm transition-colors">
            Create account
          </button>
          <p id="reg-error" class="hidden text-sm text-red-400"></p>
        </div>

        <!-- Success state (hidden until registered) -->
        <div id="reg-success" class="hidden bg-green-900/20 border border-green-700/40 rounded-xl p-6 space-y-4">
          <div class="flex items-center gap-2 text-green-400 font-semibold text-sm mb-2">
            <span>✓</span><span id="success-handle"></span> registered
          </div>

          <div>
            <p class="text-gray-300 text-sm mb-2">Your API key — <strong class="text-white">copy it now</strong>, it won't be shown again:</p>
            <div class="bg-gray-950 border border-green-800/40 rounded-xl p-4 font-mono text-sm relative group flex items-center gap-3">
              <code id="api-key-display" class="text-green-400 flex-1 select-all break-all"></code>
              <button data-copy="api-key-display" class="copy-btn shrink-0 text-xs text-gray-500 hover:text-gray-200 border border-gray-700 hover:border-gray-500 rounded px-2 py-1 transition-colors">copy</button>
            </div>
          </div>

          <div>
            <p class="text-gray-300 text-sm mb-2">Add to your shell profile:</p>
            <div class="bg-gray-950 border border-gray-800 rounded-xl p-4 font-mono text-sm relative group">
              <code id="export-cmd" class="text-green-400 select-all whitespace-pre"></code>
              <button data-copy="export-cmd" class="copy-btn absolute right-3 top-3 text-xs text-gray-600 hover:text-gray-300 transition-colors opacity-0 group-hover:opacity-100">copy</button>
            </div>
            <p class="text-xs text-gray-600 mt-1">Or <code class="text-gray-500">~/.bashrc</code> if you use bash. Then run <code class="text-gray-500">source ~/.zshrc</code>.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Step 3 -->
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-8 h-8 rounded-full bg-brand-900/60 border border-brand-500/40 flex items-center justify-center text-brand-400 font-bold text-sm">3</div>
        <h2 class="text-lg font-semibold text-white">Done</h2>
      </div>
      <p class="text-gray-400 text-sm ml-11">Signal Archive is now active. Every research task is automatically searched and (if you registered) contributed to the archive.</p>
    </div>

    <!-- What happens -->
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 mb-8">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">What happens automatically</h2>
      <div class="space-y-4">
        <div class="flex gap-4">
          <div class="text-xl shrink-0">🔍</div>
          <div>
            <div class="text-white text-sm font-medium mb-1">Before every task</div>
            <div class="text-gray-400 text-sm">Signal Archive searches for similar existing research. If matches are found, they're shown to you with similarity scores — you can reuse instead of re-running.</div>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="text-xl shrink-0">🧹</div>
          <div>
            <div class="text-white text-sm font-medium mb-1">Privacy-first sanitization</div>
            <div class="text-gray-400 text-sm">Your prompt is cleaned locally before anything leaves your machine. Private names, company context, and credentials are removed or substituted.</div>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="text-xl shrink-0">📤</div>
          <div>
            <div class="text-white text-sm font-medium mb-1">After each research task</div>
            <div class="text-gray-400 text-sm">The result is contributed to the public archive. Your handle gets credit. Reuse counts build your reputation on the leaderboard.</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Privacy note -->
    <div class="bg-yellow-900/10 border border-yellow-700/20 rounded-xl p-5 mb-8 text-sm text-yellow-200/60">
      <span class="text-yellow-400 font-semibold">Privacy: </span>
      The sanitizer runs on your machine before any data is sent. Only public-safe research is accepted.
      Public figures by name are fine. Private individuals, company context, and relative dates are
      stripped. You can review what's submitted in the archive.
    </div>

    <!-- Links -->
    <div class="flex gap-4 flex-wrap">
      <a href="https://github.com/GenAI-Gurus/signal-archive" target="_blank"
         class="bg-gray-800 hover:bg-gray-700 text-white px-5 py-2.5 rounded-lg text-sm transition-colors">
        View on GitHub →
      </a>
      <a href="/signal-archive/search"
         class="border border-gray-700 hover:border-gray-500 text-gray-300 hover:text-white px-5 py-2.5 rounded-lg text-sm transition-colors">
        Browse the archive
      </a>
      <a href="/signal-archive/leaderboard"
         class="border border-gray-700 hover:border-gray-500 text-gray-300 hover:text-white px-5 py-2.5 rounded-lg text-sm transition-colors">
        Leaderboard
      </a>
    </div>
  </div>
</Base>

<script>
  const API_URL = 'https://signal-archive-api.fly.dev';

  // Copy buttons
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-copy');
      const text = document.getElementById(targetId).textContent;
      navigator.clipboard.writeText(text).then(() => {
        const original = btn.textContent;
        btn.textContent = 'copied';
        setTimeout(() => { btn.textContent = original; }, 1500);
      });
    });
  });

  // Registration form
  const handleInput = document.getElementById('handle-input');
  const nameInput = document.getElementById('name-input');
  const regBtn = document.getElementById('reg-btn');
  const regError = document.getElementById('reg-error');
  const regForm = document.getElementById('reg-form');
  const regSuccess = document.getElementById('reg-success');

  function showError(msg) {
    regError.textContent = msg;
    regError.classList.remove('hidden');
    regBtn.disabled = false;
    regBtn.textContent = 'Create account';
  }

  regBtn.addEventListener('click', async () => {
    const handle = handleInput.value.trim().toLowerCase();
    const displayName = nameInput.value.trim() || null;

    if (!handle) { showError('Handle is required.'); return; }
    if (!/^[a-z0-9][a-z0-9\-]{1,38}[a-z0-9]$/.test(handle)) {
      showError('Handle must be 3–40 characters: lowercase letters, numbers, hyphens. Cannot start or end with a hyphen.');
      return;
    }

    regError.classList.add('hidden');
    regBtn.disabled = true;
    regBtn.textContent = 'Creating…';

    try {
      const res = await fetch(`${API_URL}/contributors`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ handle, display_name: displayName }),
      });

      if (res.status === 409) { showError('That handle is already taken. Try a different one.'); return; }
      if (!res.ok) { showError(`Registration failed (${res.status}). Please try again.`); return; }

      const data = await res.json();

      // Show success state
      regForm.classList.add('hidden');
      regSuccess.classList.remove('hidden');
      document.getElementById('success-handle').textContent = '@' + data.handle;
      document.getElementById('api-key-display').textContent = data.api_key;
      document.getElementById('export-cmd').textContent =
        `echo 'export SIGNAL_ARCHIVE_API_KEY="${data.api_key}"' >> ~/.zshrc\nsource ~/.zshrc`;

    } catch (err) {
      showError('Network error. Check your connection and try again.');
    }
  });

  // Submit on Enter in handle field
  handleInput.addEventListener('keydown', e => {
    if (e.key === 'Enter') regBtn.click();
  });
</script>
