---
import Base from '../layouts/Base.astro';
---

<Base title="Get Started" description="Install Signal Archive in 3 steps — works with Claude Code and Codex CLI">
  <div class="max-w-3xl mx-auto">
    <div class="mb-10">
      <h1 class="text-3xl font-bold text-white mb-3">Get Started</h1>
      <p class="text-xl text-gray-400">
        Signal Archive hooks into your Claude Code. Before each research task it checks
        what's already been answered. After each task it contributes your result back — automatically.
      </p>
    </div>

    <!-- Prerequisites -->
    <div class="mb-10 bg-gray-900 border border-gray-800 rounded-xl p-6">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Prerequisites</h2>
      <p class="text-gray-300 text-sm mb-3">You need Claude Code installed:</p>
      <div class="flex gap-4 flex-wrap">
        <a href="https://claude.ai/code" target="_blank"
           class="flex items-center gap-2 bg-gray-800 hover:bg-gray-700 border border-gray-700 rounded-lg px-4 py-3 transition-colors">
          <span class="text-brand-400 font-bold text-sm">Claude Code</span>
          <span class="text-gray-500 text-xs">claude.ai/code</span>
        </a>
      </div>
      <p class="text-xs text-gray-500 mt-3">Uses your existing Claude subscription — no separate API key needed.</p>
    </div>

    <!-- Step 1 -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-8 h-8 rounded-full bg-brand-900/60 border border-brand-500/40 flex items-center justify-center text-brand-400 font-bold text-sm">1</div>
        <h2 class="text-lg font-semibold text-white">Install the plugin</h2>
      </div>
      <p class="text-gray-400 text-sm mb-3 ml-11">Run these three commands inside Claude Code:</p>
      <div class="ml-11 space-y-3">
        <div class="bg-gray-950 border border-gray-800 rounded-xl p-4 font-mono text-sm relative group">
          <code id="plugin-add-cmd" class="text-green-400 select-all">/plugin marketplace add https://github.com/GenAI-Gurus/signal-archive</code>
          <button data-copy="plugin-add-cmd" class="copy-btn absolute right-3 top-3 text-xs text-gray-600 hover:text-gray-300 transition-colors opacity-0 group-hover:opacity-100">copy</button>
        </div>
        <div class="bg-gray-950 border border-gray-800 rounded-xl p-4 font-mono text-sm relative group">
          <code id="plugin-install-cmd" class="text-green-400 select-all">/plugin install signal-archive</code>
          <button data-copy="plugin-install-cmd" class="copy-btn absolute right-3 top-3 text-xs text-gray-600 hover:text-gray-300 transition-colors opacity-0 group-hover:opacity-100">copy</button>
        </div>
        <div class="bg-gray-950 border border-gray-800 rounded-xl p-4 font-mono text-sm relative group">
          <code id="plugin-reload-cmd" class="text-green-400 select-all">/reload-plugins</code>
          <button data-copy="plugin-reload-cmd" class="copy-btn absolute right-3 top-3 text-xs text-gray-600 hover:text-gray-300 transition-colors opacity-0 group-hover:opacity-100">copy</button>
        </div>
        <p class="text-xs text-gray-600">That's it for read-only search. Complete step 2 to enable automatic contribution.</p>
      </div>
    </div>

    <!-- Step 2: Register -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-8 h-8 rounded-full bg-brand-900/60 border border-brand-500/40 flex items-center justify-center text-brand-400 font-bold text-sm">2</div>
        <h2 class="text-lg font-semibold text-white">Register</h2>
      </div>
      <p class="text-gray-400 text-sm mb-4 ml-11">Free, no password. Enter your email and click the link we send.</p>
      <div class="ml-11">
        <div id="email-form" class="bg-gray-900 border border-gray-800 rounded-xl p-6 space-y-4">
          <div>
            <label for="gs-email" class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Email <span class="text-brand-500">*</span></label>
            <input id="gs-email" type="email" placeholder="you@example.com"
              class="w-full bg-gray-950 border border-gray-700 focus:border-brand-500 rounded-lg px-4 py-2.5 text-white text-sm outline-none transition-colors placeholder-gray-600" />
          </div>
          <button id="gs-send-btn"
            class="bg-brand-600 hover:bg-brand-500 disabled:opacity-50 text-white font-semibold px-6 py-2.5 rounded-lg text-sm transition-colors">
            Send magic link
          </button>
          <p id="gs-error" class="hidden text-sm text-red-400"></p>
        </div>
        <div id="gs-check-email" class="hidden bg-green-900/20 border border-green-700/40 rounded-xl p-6 text-center">
          <div class="text-2xl mb-2">📬</div>
          <p class="text-gray-300 text-sm">
            Magic link sent to <strong id="gs-sent-to" class="text-white"></strong>.<br>
            Click it in your email — expires in 15 minutes.
          </p>
        </div>
      </div>
    </div>

    <!-- Step 3 -->
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-8 h-8 rounded-full bg-brand-900/60 border border-brand-500/40 flex items-center justify-center text-brand-400 font-bold text-sm">3</div>
        <h2 class="text-lg font-semibold text-white">Done</h2>
      </div>
      <p class="text-gray-400 text-sm ml-11">Signal Archive is now active. Every research task is automatically searched and (if you registered) contributed to the archive.</p>
    </div>

    <!-- What happens -->
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 mb-8">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">What happens automatically</h2>
      <div class="space-y-4">
        <div class="flex gap-4">
          <div class="text-xl shrink-0">🔍</div>
          <div>
            <div class="text-white text-sm font-medium mb-1">Before every task</div>
            <div class="text-gray-400 text-sm">Signal Archive searches for similar existing research. If matches are found, they're shown to you with similarity scores — you can reuse instead of re-running.</div>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="text-xl shrink-0">🧹</div>
          <div>
            <div class="text-white text-sm font-medium mb-1">Privacy-first sanitization</div>
            <div class="text-gray-400 text-sm">Your prompt is cleaned locally before anything leaves your machine. Private names, company context, and credentials are removed or substituted.</div>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="text-xl shrink-0">📤</div>
          <div>
            <div class="text-white text-sm font-medium mb-1">After each research task</div>
            <div class="text-gray-400 text-sm">The result is contributed to the public archive. Your handle gets credit. Reuse counts build your reputation on the leaderboard.</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Privacy note -->
    <div class="bg-yellow-900/10 border border-yellow-700/20 rounded-xl p-5 mb-8 text-sm text-yellow-200/60">
      <span class="text-yellow-400 font-semibold">Privacy: </span>
      The sanitizer runs on your machine before any data is sent. Only public-safe research is accepted.
      Public figures by name are fine. Private individuals, company context, and relative dates are
      stripped. You can review what's submitted in the archive.
    </div>

    <!-- Links -->
    <div class="flex gap-4 flex-wrap">
      <a href="https://github.com/GenAI-Gurus/signal-archive" target="_blank"
         class="bg-gray-800 hover:bg-gray-700 text-white px-5 py-2.5 rounded-lg text-sm transition-colors">
        View on GitHub →
      </a>
      <a href="/signal-archive/search"
         class="border border-gray-700 hover:border-gray-500 text-gray-300 hover:text-white px-5 py-2.5 rounded-lg text-sm transition-colors">
        Browse the archive
      </a>
      <a href="/signal-archive/leaderboard"
         class="border border-gray-700 hover:border-gray-500 text-gray-300 hover:text-white px-5 py-2.5 rounded-lg text-sm transition-colors">
        Leaderboard
      </a>
    </div>
  </div>
</Base>

<script>
  const API_URL = import.meta.env.PUBLIC_API_URL || 'https://signal-archive-api.fly.dev';

  // Copy buttons
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = document.getElementById(btn.getAttribute('data-copy')).textContent;
      navigator.clipboard.writeText(text).then(() => {
        const orig = btn.textContent;
        btn.textContent = 'copied';
        setTimeout(() => { btn.textContent = orig; }, 1500);
      });
    });
  });

  // Email form
  const gsEmail = document.getElementById('gs-email');
  const gsSendBtn = document.getElementById('gs-send-btn');
  const gsError = document.getElementById('gs-error');

  gsSendBtn.addEventListener('click', async () => {
    const email = gsEmail.value.trim();
    if (!email || !email.includes('@')) {
      gsError.textContent = 'Enter a valid email address.';
      gsError.classList.remove('hidden');
      return;
    }
    gsError.classList.add('hidden');
    gsSendBtn.disabled = true;
    gsSendBtn.textContent = 'Sending…';
    try {
      const r = await fetch(`${API_URL}/auth/request-login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      if (!r.ok) throw new Error();
      document.getElementById('gs-sent-to').textContent = email;
      document.getElementById('email-form').classList.add('hidden');
      document.getElementById('gs-check-email').classList.remove('hidden');
    } catch {
      gsError.textContent = 'Something went wrong. Please try again.';
      gsError.classList.remove('hidden');
      gsSendBtn.disabled = false;
      gsSendBtn.textContent = 'Send magic link';
    }
  });

  gsEmail.addEventListener('keydown', e => { if (e.key === 'Enter') gsSendBtn.click(); });
</script>
