---
import Base from '../layouts/Base.astro';
---

<Base title="Leaderboard">
  <h1 class="text-3xl font-bold text-white mb-2">Leaderboard</h1>
  <p class="text-gray-400 mb-10">Top contributors ranked by research others actually reused.</p>
  <div id="leaderboard" class="space-y-3"></div>
</Base>

<script>
  import { isLoggedIn } from '../lib/auth.js';
  import { getLeaderboard, el, link, BASE } from '../lib/api.js';

  getLeaderboard().then(items => {
    const container = document.getElementById('leaderboard');
    if (!items.length) {
      container.appendChild(el('p', 'text-gray-500 italic', 'No contributors yet.'));
      return;
    }
    items.forEach((c, i) => {
      const row = el('div', 'flex items-center gap-4 bg-gray-900 border border-gray-800 rounded-xl px-6 py-4');
      row.appendChild(el('span', 'text-2xl font-bold font-mono text-gray-700 w-8', String(i + 1)));
      const info = el('div', 'flex-1 min-w-0');
      info.appendChild(link(`${BASE}/contributor/?handle=${c.handle}`, 'font-semibold text-white hover:text-brand-400 transition-colors', c.display_name || c.handle));
      info.appendChild(el('div', 'text-xs text-gray-600 font-mono', '@' + c.handle));
      row.appendChild(info);
      const repScore = Math.round(c.reputation_score ?? 0);
      const repColor = repScore >= 75 ? 'text-green-400 border-green-800 bg-green-900/20'
                     : repScore >= 40 ? 'text-yellow-400 border-yellow-800 bg-yellow-900/20'
                     : 'text-gray-400 border-gray-700 bg-gray-800/40';
      const rep = el('div', 'text-center shrink-0');
      rep.appendChild(el('div', `text-lg font-bold font-mono ${repScore >= 75 ? 'text-green-400' : repScore >= 40 ? 'text-yellow-400' : 'text-gray-400'}`, String(repScore)));
      rep.appendChild(el('div', 'text-xs text-gray-600 uppercase tracking-wider', 'rep'));
      row.appendChild(rep);
      const stats = el('div', 'text-right text-xs text-gray-500 space-y-1 shrink-0');
      stats.appendChild(el('div', null, `📄 ${c.total_contributions}`));
      stats.appendChild(el('div', null, `♻️ ${c.total_reuse_count}`));
      row.appendChild(stats);
      container.appendChild(row);
    });
    if (!isLoggedIn() && items.length >= 5) {
      const banner = document.createElement('div');
      banner.className = 'mt-4 p-4 bg-gray-900 border border-gray-800 rounded-xl text-center';
      const msg = document.createElement('p');
      msg.className = 'text-gray-400 text-sm mb-3';
      msg.textContent = 'Sign in to see the full leaderboard.';
      const btn = document.createElement('a');
      btn.href = BASE + '/login';
      btn.className = 'bg-brand-600 hover:bg-brand-500 text-white font-semibold px-6 py-2.5 rounded-lg text-sm transition-colors';
      btn.textContent = 'Sign in';
      banner.appendChild(msg);
      banner.appendChild(btn);
      document.getElementById('leaderboard').appendChild(banner);
    }
  });
</script>
