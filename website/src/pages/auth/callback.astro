---
import Base from '../../layouts/Base.astro';
---
<Base title="Signing in" description="Completing sign-in">
  <div class="max-w-md mx-auto mt-10">

    <div id="state-loading" class="text-center py-12 text-gray-400">Verifying your link…</div>

    <div id="state-new-user" class="hidden">
      <h1 class="text-2xl font-bold text-white mb-2">Almost there</h1>
      <p class="text-gray-400 mb-6 text-sm">Pick a public handle for the leaderboard.</p>
      <div class="space-y-4">
        <div>
          <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">
            Handle <span class="text-brand-500">*</span>
          </label>
          <input id="handle-input" type="text" placeholder="e.g. alice or research-bot"
            class="w-full bg-gray-900 border border-gray-700 focus:border-brand-500 rounded-lg px-4 py-2.5 text-white text-sm font-mono outline-none transition-colors placeholder-gray-600" />
          <p class="text-xs text-gray-600 mt-1">Lowercase letters, numbers, hyphens. 3–40 chars.</p>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">
            Display name <span class="text-gray-600">(optional)</span>
          </label>
          <input id="name-input" type="text" placeholder="e.g. Alice Smith"
            class="w-full bg-gray-900 border border-gray-700 focus:border-brand-500 rounded-lg px-4 py-2.5 text-white text-sm outline-none transition-colors placeholder-gray-600" />
        </div>
        <button id="create-btn"
          class="w-full bg-brand-600 hover:bg-brand-500 disabled:opacity-50 text-white font-semibold py-3 rounded-lg text-sm transition-colors">
          Create account
        </button>
        <p id="handle-error" class="hidden text-sm text-red-400"></p>
      </div>
    </div>

    <div id="state-success" class="hidden">
      <div class="text-center mb-6">
        <div class="text-4xl mb-3">&#x2713;</div>
        <h1 class="text-xl font-bold text-white mb-1">
          Signed in as <span id="success-handle" class="text-brand-400"></span>
        </h1>
        <p class="text-gray-400 text-sm">You now have full access to search and discovery.</p>
      </div>

      <div id="api-key-section" class="hidden bg-gray-900 border border-gray-800 rounded-xl p-5 mb-6">
        <p class="text-sm text-gray-300 mb-3">
          Your plugin API key — <strong class="text-white">copy it now</strong>:
        </p>
        <div class="bg-gray-950 border border-green-800/40 rounded-lg p-3 font-mono text-xs flex items-center gap-3 mb-3">
          <code id="api-key-display" class="text-green-400 flex-1 select-all break-all"></code>
          <button id="copy-key-btn"
            class="shrink-0 text-xs text-gray-500 hover:text-gray-200 border border-gray-700 rounded px-2 py-1 transition-colors">
            copy
          </button>
        </div>
        <div class="bg-gray-950 border border-gray-800 rounded-lg p-3 font-mono text-xs relative group mb-1">
          <code id="export-cmd" class="text-green-400 select-all whitespace-pre"></code>
          <button id="copy-export-btn"
            class="absolute right-2 top-2 text-xs text-gray-600 hover:text-gray-300 opacity-0 group-hover:opacity-100 transition-colors">
            copy
          </button>
        </div>
        <p class="text-xs text-gray-600">
          Add to <code class="text-gray-500">~/.zshrc</code> or <code class="text-gray-500">~/.bashrc</code>
        </p>
      </div>

      <div class="flex gap-3">
        <a id="link-search" href="#"
          class="flex-1 text-center bg-brand-600 hover:bg-brand-500 text-white font-semibold py-2.5 rounded-lg text-sm transition-colors">
          Search the archive
        </a>
        <a id="link-discovery" href="#"
          class="flex-1 text-center border border-gray-700 hover:border-gray-500 text-gray-300 hover:text-white py-2.5 rounded-lg text-sm transition-colors">
          Discovery
        </a>
      </div>
    </div>

    <div id="state-error" class="hidden text-center py-12">
      <div class="text-4xl mb-3">&#x2717;</div>
      <p id="error-detail" class="text-red-400 text-sm"></p>
      <a id="link-retry" href="#" class="mt-4 inline-block text-brand-400 hover:text-brand-300 text-sm">
        Try again
      </a>
    </div>
  </div>
</Base>

<script>
  import { setToken } from '../../lib/auth.js';
  import { BASE } from '../../lib/api.js';

  const API_URL = import.meta.env.PUBLIC_API_URL || 'https://signal-archive-api.fly.dev';
  const params = new URLSearchParams(window.location.search);
  const magicToken = params.get('token');

  // Wire static links using BASE (no template injection into DOM)
  document.getElementById('link-search').href = BASE + '/search';
  document.getElementById('link-discovery').href = BASE + '/discovery';
  const cliSession = params.get('cli_session');
  document.getElementById('link-retry').href = BASE + '/login' + (cliSession ? `?cli_session=${encodeURIComponent(cliSession)}` : '');

  function show(stateId) {
    ['state-loading','state-new-user','state-success','state-error'].forEach(id => {
      document.getElementById(id).classList.toggle('hidden', id !== stateId);
    });
  }

  function showError(msg) {
    document.getElementById('error-detail').textContent = msg;
    show('state-error');
  }

  async function submitVerify(handle, displayName) {
    const body = { token: magicToken };
    if (handle) body.handle = handle;
    if (displayName) body.display_name = displayName;

    const r = await fetch(`${API_URL}/auth/verify`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });

    if (r.status === 409) {
      document.getElementById('handle-error').textContent = 'That handle is already taken.';
      document.getElementById('handle-error').classList.remove('hidden');
      const btn = document.getElementById('create-btn');
      btn.disabled = false;
      btn.textContent = 'Create account';
      return;
    }
    if (!r.ok) {
      const err = await r.json().catch(() => ({}));
      showError(err.detail || 'Verification failed. The link may have expired.');
      return;
    }

    const data = await r.json();
    setToken(data.jwt);
    document.getElementById('success-handle').textContent = '@' + data.handle;

    if (data.is_new && data.api_key) {
      document.getElementById('api-key-section').classList.remove('hidden');
      document.getElementById('api-key-display').textContent = data.api_key;
      // Build export command using textContent only
      document.getElementById('export-cmd').textContent =
        "echo 'export SIGNAL_ARCHIVE_API_KEY=\"" + data.api_key + "\"' >> ~/.zshrc\nsource ~/.zshrc";
    }
    show('state-success');
  }

  async function init() {
    if (!magicToken) { showError('No token in URL.'); return; }

    // First call: no handle — returns 422 for new users, 200 for returning users
    const r = await fetch(`${API_URL}/auth/verify`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token: magicToken }),
    });

    if (r.status === 422) {
      // New user — needs to pick a handle
      show('state-new-user');
      document.getElementById('create-btn').addEventListener('click', async () => {
        const btn = document.getElementById('create-btn');
        btn.disabled = true;  // prevent double-submission immediately
        const handle = document.getElementById('handle-input').value.trim().toLowerCase();
        const displayName = document.getElementById('name-input').value.trim() || null;
        if (!/^[a-z0-9][a-z0-9\-]{1,38}[a-z0-9]$/.test(handle)) {
          document.getElementById('handle-error').textContent =
            'Handle must be 3-40 chars: lowercase letters, numbers, hyphens.';
          document.getElementById('handle-error').classList.remove('hidden');
          btn.disabled = false;  // re-enable on validation failure
          return;
        }
        btn.textContent = 'Creating…';
        await submitVerify(handle, displayName);
      });
      return;
    }

    if (r.ok) {
      const data = await r.json();
      setToken(data.jwt);
      document.getElementById('success-handle').textContent = '@' + data.handle;
      show('state-success');
      return;
    }

    const err = await r.json().catch(() => ({}));
    showError(err.detail || 'Link invalid or expired.');
  }

  init();

  document.getElementById('copy-key-btn')?.addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('api-key-display').textContent);
    const btn = document.getElementById('copy-key-btn');
    btn.textContent = 'copied';
    setTimeout(() => { btn.textContent = 'copy'; }, 1500);
  });
  document.getElementById('copy-export-btn')?.addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('export-cmd').textContent);
    const btn = document.getElementById('copy-export-btn');
    btn.textContent = 'copied';
    setTimeout(() => { btn.textContent = 'copy'; }, 1500);
  });
</script>
